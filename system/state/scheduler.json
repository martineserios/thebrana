{
  "defaults": {
    "allowedTools": "Read,Glob,Grep,WebSearch",
    "logRetention": 30,
    "model": "haiku",
    "timeoutSeconds": 300
  },
  "jobs": {
    "agentdb-watch": {
      "_comment": "Daily check: has AgentDB integration shipped?",
      "captureOutput": true,
      "command": "./system/scheduler/check-agentdb-integration.sh",
      "enabled": true,
      "maxRetries": 1,
      "project": "~/enter_thebrana/thebrana",
      "retryBackoffSec": 60,
      "schedule": "*-*-* 08:06:00",
      "type": "command"
    },
    "backup-memory": {
      "_comment": "Daily rotating backup of ruflo memory.db (before sync-state push)",
      "captureOutput": true,
      "command": "./system/scripts/backup-memory.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 07:00:00",
      "timeoutSeconds": 30,
      "type": "command"
    },
    "cc-changelog-review": {
      "_comment": "Weekly CC changelog diff — writes ~/.claude/cc-changelog-report.md if changes found (t-512)",
      "captureOutput": true,
      "command": "./system/scripts/cc-changelog-check.sh",
      "enabled": true,
      "maxRetries": 1,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:18:00",
      "timeoutSeconds": 60,
      "type": "command"
    },
    "close-extraction": {
      "_comment": "ADR-052 Track 2: nightly extraction — agy pass per queued close snapshot, learnings to reminders, daily summary.",
      "captureOutput": true,
      "command": "./system/cron/close-extraction.sh",
      "enabled": true,
      "maxRetries": 1,
      "project": "~/enter_thebrana/thebrana",
      "retryBackoffSec": 300,
      "schedule": "*-*-* 02:00:00",
      "timeoutSeconds": 1800,
      "type": "command"
    },
    "content-harvest": {
      "_comment": "t-680: weekly content harvest. Synced from template 2026-05-25 (t-1680) — was silently missing from live.",
      "allowedTools": "Read,Glob,Grep,Bash",
      "captureOutput": true,
      "enabled": true,
      "model": "sonnet",
      "project": "~/enter_thebrana/ventures/linkedin",
      "schedule": "Sun *-*-* 22:00:00",
      "skill": "/brana:harvest 7d --auto",
      "timeoutSeconds": 600,
      "type": "skill"
    },
    "daily-digest": {
      "_comment": "t-688: daily Telegram digest summarizing all scheduler runs. Enable on Oracle only (requires ~/.hub-secrets).",
      "captureOutput": false,
      "command": "./system/scheduler/brana-scheduler-digest.sh",
      "enabled": false,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 09:30:00",
      "timeoutSeconds": 30,
      "type": "command"
    },
    "export-patterns": {
      "_comment": "ADR-015: weekly JSON export of all ruflo namespaces to git",
      "captureOutput": true,
      "command": "./system/scripts/sync-state.sh export --auto-commit",
      "enabled": true,
      "maxRetries": 1,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 08:30:00",
      "timeoutSeconds": 120,
      "type": "command"
    },
    "feed-index": {
      "_comment": "t-1009: daily intelligence digest — feed-log.jsonl → ~/.claude/intelligence-feed-digest.md",
      "captureOutput": true,
      "command": "./system/scripts/feed-index.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 19:00:00",
      "timeoutSeconds": 60,
      "type": "command"
    },
    "feed-poll": {
      "_comment": "t-1009: poll all registered RSS/Atom feeds 3x daily",
      "captureOutput": true,
      "command": "brana feed poll --all",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08,12,18:00:00",
      "timeoutSeconds": 120,
      "type": "command"
    },
    "feed-ruflo-index": {
      "_comment": "t-1138: store new feed entries to ruflo memory_entries for semantic search. Timeout 3600: indexing runs ~2 sections/s; backfill bulges (2026-06-12: 1783 sections ≈ 20min) blow a 300s cap",
      "captureOutput": true,
      "command": "./system/scripts/feed-ruflo-index.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 19:15:00",
      "timeoutSeconds": 3600,
      "type": "command"
    },
    "feed-summarize": {
      "_comment": "t-1139: fetch anthropic-news article URLs, summarize via claude -p → feed-summaries.jsonl (feed-index joins at 19:00). Timeout 3600: backfill bulges (2026-06-12: 230 entries × ~15s) blow a 300s cap",
      "captureOutput": true,
      "command": "./system/scripts/feed-summarize.sh",
      "enabled": true,
      "maxRetries": 1,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 18:55:00",
      "timeoutSeconds": 3600,
      "type": "command"
    },
    "inbox-poll": {
      "_comment": "t-585: poll Gmail for new newsletter emails.",
      "captureOutput": true,
      "command": "brana inbox poll",
      "enabled": false,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 09:00:00",
      "timeoutSeconds": 60,
      "type": "command"
    },
    "index-assumptions": {
      "captureOutput": true,
      "command": "./system/scripts/index-assumptions.sh",
      "enabled": true,
      "maxRetries": 1,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 08:36:00",
      "timeoutSeconds": 300,
      "type": "command"
    },
    "knowledge-decay": {
      "_comment": "t-936/t-1102: weekly DECAY — stale dimensions, event log bloat, ruflo noise. Runs after reindex-knowledge (noon).",
      "allowedTools": "Read,Glob,Grep,Bash",
      "captureOutput": true,
      "enabled": true,
      "maxRetries": 1,
      "model": "sonnet",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 13:00:00",
      "skill": "/brana:reconcile --scope knowledge",
      "timeoutSeconds": 600,
      "type": "skill"
    },
    "knowledge-pipeline-tier1": {
      "_comment": "t-1136: nightly Tier 1+2 LinkedIn URL relevance filter + cluster assignment. Enabled 2026-04-12 after dry-run passed clean. Tier 3 is manual only.",
      "captureOutput": true,
      "command": "brana knowledge process --tier1 && brana knowledge process --tier2",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "0 3 * * *",
      "timeoutSeconds": 300,
      "type": "command"
    },
    "knowledge-review": {
      "_comment": "Monthly knowledge health check",
      "allowedTools": "Read,Glob,Grep,WebSearch,WebFetch",
      "enabled": true,
      "model": "sonnet",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-01 10:00:00",
      "skill": "/brana:memory review",
      "type": "skill"
    },
    "link-check": {
      "_comment": "Weekly dead link check (enable after lychee is installed)",
      "command": "lychee --config .lychee.toml *.md",
      "enabled": false,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 09:00:00",
      "type": "command"
    },
    "lint-heal": {
      "_comment": "t-1075: weekly L2 memory lint+heal — dedup, contradiction detection, frontmatter imputation. Runs after knowledge-decay (13:00).",
      "captureOutput": true,
      "command": "./system/scripts/lint-heal.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 15:00:00",
      "timeoutSeconds": 300,
      "type": "command"
    },
    "memory-consolidation": {
      "_comment": "t-1834: threshold-triggered L3 consolidation — debrief-flag consumption + frontmatter date normalization. OR trigger: >24h OR >=5 sessions. Does NOT call lint-heal.sh (no lock collision). Runs Mon-Sat only (Sun handled by lint-heal at 15:00 which resets session counter).",
      "captureOutput": true,
      "command": "./system/scripts/memory-consolidation.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon,Tue,Wed,Thu,Fri,Sat *-*-* 15:30:00",
      "timeoutSeconds": 120,
      "type": "command"
    },
    "morning-check": {
      "_comment": "Daily morning focus card — disabled locally (runs on Oracle for Telegram)",
      "enabled": false,
      "model": "haiku",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon..Fri *-*-* 08:48:00",
      "skill": "/brana:daily-ops",
      "type": "skill"
    },
    "reindex-knowledge": {
      "_comment": "Weekly full reindex — runs at noon Sun (moved from 2am: cold-boot MCP unavailable, t-1101)",
      "captureOutput": true,
      "command": "./system/scripts/index-knowledge.sh",
      "enabled": true,
      "maxRetries": 1,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 12:00:00",
      "timeoutSeconds": 10800,
      "type": "command"
    },
    "reindex-patterns": {
      "_comment": "Weekly pattern namespace reindex — runs at 3am (after knowledge reindex), ~1h max (t-857)",
      "captureOutput": true,
      "command": "./system/scripts/index-patterns.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 03:00:00",
      "timeoutSeconds": 3600,
      "type": "command"
    },
    "second-phase-review": {
      "_comment": "ADR-021: weekly check for time-gated second-phase tasks",
      "captureOutput": true,
      "command": "./system/scripts/second-phase-check.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:42:00",
      "timeoutSeconds": 60,
      "type": "command"
    },
    "staleness-report": {
      "_comment": "Weekly staleness check on spec docs",
      "command": "./scripts/staleness-report.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:12:00",
      "type": "command"
    },
    "statusline-slow-cache": {
      "_comment": "t-1023: write ruflo health, portfolio pulse, knowledge freshness to statusline slow-cache every 5min",
      "captureOutput": true,
      "command": "./system/scripts/statusline-slow-cache.sh",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* *:00/5:00",
      "timeoutSeconds": 30,
      "type": "command"
    },
    "sync-state": {
      "_comment": "ADR-015: daily safety net — sync operational state from cache to repos",
      "captureOutput": true,
      "command": "./system/scripts/sync-state.sh push --auto-commit",
      "enabled": true,
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08:00:00",
      "timeoutSeconds": 60,
      "type": "command"
    },
    "weekly-review": {
      "_comment": "Friday weekly portfolio review",
      "enabled": true,
      "model": "sonnet",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Fri *-*-* 17:00:00",
      "skill": "/brana:review",
      "type": "skill"
    }
  },
  "version": 1
}
