{
  "version": 1,
  "defaults": {
    "model": "haiku",
    "allowedTools": "Read,Glob,Grep,WebSearch",
    "logRetention": 30,
    "timeoutSeconds": 300
  },
  "jobs": {
    "backup-memory": {
      "type": "command",
      "command": "./system/scripts/backup-memory.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 07:00:00",
      "enabled": true,
      "timeoutSeconds": 30,
      "captureOutput": true,
      "_comment": "Daily rotating backup of ruflo memory.db (before sync-state push)"
    },
    "sync-state": {
      "type": "command",
      "command": "./system/scripts/sync-state.sh push --auto-commit",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08:00:00",
      "enabled": true,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "ADR-015: daily safety net \u2014 sync operational state from cache to repos"
    },
    "agentdb-watch": {
      "type": "command",
      "command": "./system/scheduler/check-agentdb-integration.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08:06:00",
      "enabled": true,
      "maxRetries": 1,
      "retryBackoffSec": 60,
      "captureOutput": true,
      "_comment": "Daily check: has AgentDB integration shipped?"
    },
    "staleness-report": {
      "type": "command",
      "command": "./scripts/staleness-report.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:12:00",
      "enabled": true,
      "_comment": "Weekly staleness check on spec docs"
    },
    "cc-changelog-review": {
      "type": "command",
      "command": "./system/scripts/cc-changelog-check.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:18:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "Weekly CC changelog diff \u2014 writes ~/.claude/cc-changelog-report.md if changes found (t-512)"
    },
    "reindex-knowledge": {
      "type": "command",
      "command": "./system/scripts/index-knowledge.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 12:00:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 10800,
      "captureOutput": true,
      "_comment": "Weekly full reindex \u2014 runs at noon Sun (moved from 2am: cold-boot MCP unavailable, t-1101)"
    },
    "knowledge-decay": {
      "type": "skill",
      "skill": "/brana:reconcile --scope knowledge",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 13:00:00",
      "model": "sonnet",
      "allowedTools": "Read,Glob,Grep,Bash",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 600,
      "captureOutput": true,
      "_comment": "t-936/t-1102: weekly DECAY \u2014 stale dimensions, event log bloat, ruflo noise. Runs after reindex-knowledge (noon)."
    },
    "reindex-patterns": {
      "type": "command",
      "command": "./system/scripts/index-patterns.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 03:00:00",
      "enabled": true,
      "timeoutSeconds": 3600,
      "captureOutput": true,
      "_comment": "Weekly pattern namespace reindex \u2014 runs at 3am (after knowledge reindex), ~1h max (t-857)"
    },
    "export-patterns": {
      "type": "command",
      "command": "./system/scripts/sync-state.sh export --auto-commit",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 08:30:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 120,
      "captureOutput": true,
      "_comment": "ADR-015: weekly JSON export of all ruflo namespaces to git"
    },
    "knowledge-review": {
      "type": "skill",
      "skill": "/brana:memory review",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-01 10:00:00",
      "model": "sonnet",
      "allowedTools": "Read,Glob,Grep,WebSearch,WebFetch",
      "enabled": true,
      "_comment": "Monthly knowledge health check"
    },
    "weekly-review": {
      "type": "skill",
      "skill": "/brana:review",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Fri *-*-* 17:00:00",
      "model": "sonnet",
      "enabled": true,
      "_comment": "Friday weekly portfolio review"
    },
    "morning-check": {
      "type": "skill",
      "skill": "/brana:daily-ops",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon..Fri *-*-* 08:48:00",
      "model": "haiku",
      "enabled": false,
      "_comment": "Daily morning focus card \u2014 disabled locally (runs on Oracle for Telegram)"
    },
    "link-check": {
      "type": "command",
      "command": "lychee --config .lychee.toml *.md",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 09:00:00",
      "enabled": false,
      "_comment": "Weekly dead link check (enable after lychee is installed)"
    },
    "feed-poll": {
      "type": "command",
      "command": "brana feed poll --all",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08,12,18:00:00",
      "enabled": true,
      "timeoutSeconds": 120,
      "captureOutput": true,
      "_comment": "t-1009: poll all registered RSS/Atom feeds 3x daily"
    },
    "feed-index": {
      "type": "command",
      "command": "./system/scripts/feed-index.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 19:00:00",
      "enabled": true,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "t-1009: daily intelligence digest — feed-log.jsonl → ~/.claude/intelligence-feed-digest.md"
    },
    "feed-ruflo-index": {
      "type": "command",
      "command": "./system/scripts/feed-ruflo-index.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 19:15:00",
      "enabled": true,
      "timeoutSeconds": 300,
      "captureOutput": true,
      "_comment": "t-1138: store new feed entries to ruflo memory_entries for semantic search"
    },
    "lint-heal": {
      "type": "command",
      "command": "./system/scripts/lint-heal.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 15:00:00",
      "enabled": true,
      "timeoutSeconds": 300,
      "captureOutput": true,
      "_comment": "t-1075: weekly L2 memory lint+heal — dedup, contradiction detection, frontmatter imputation. Runs after knowledge-decay (13:00)."
    },
    "index-assumptions": {
      "type": "command",
      "command": "./system/scripts/index-assumptions.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 08:36:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 300,
      "captureOutput": true
    },
    "second-phase-review": {
      "type": "command",
      "command": "./system/scripts/second-phase-check.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:42:00",
      "enabled": true,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "ADR-021: weekly check for time-gated second-phase tasks"
    },
    "statusline-slow-cache": {
      "type": "command",
      "command": "./system/scripts/statusline-slow-cache.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* *:00/5:00",
      "enabled": true,
      "timeoutSeconds": 30,
      "captureOutput": true,
      "_comment": "t-1023: write ruflo health, portfolio pulse, knowledge freshness to statusline slow-cache every 5min"
    },
    "knowledge-pipeline-tier1": {
      "type": "command",
      "command": "brana knowledge process --tier1 && brana knowledge process --tier2",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "0 3 * * *",
      "enabled": false,
      "timeoutSeconds": 300,
      "captureOutput": true,
      "_comment": "t-1136: nightly Tier 1+2 LinkedIn URL relevance filter + cluster assignment. Enable manually after dry-run passes clean. Tier 3 is manual only."
    }
  }
}
