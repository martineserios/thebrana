{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/tdd-gate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "continueOnBlock": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/feedback-gate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "continueOnBlock": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/memory-write-gate.sh"
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/plan-mode-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/worktree-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/doc-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/main-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/branch-verify.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/branch-name-warn.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/no-attribution-commit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/commit-msg-verify.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/rust-skills-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "timeout": 2000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/skill-sentinel.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "continueOnBlock": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-plan-challenge.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-pr-review.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/task-completed.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hallucination-detect.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/bash-output-compress.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-sale.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "continueOnBlock": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-tasks-validate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 10000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-hooks-json.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "async": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/memory-index-sync.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-failure.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/preflight-model.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/context-inject.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/signal-capture.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 10000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/cc-changelog-check.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-context.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-tracker.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-tracker.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/step-completed.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 10000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stopfailure-logger.sh"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/config-change-guard.sh"
          }
        ]
      }
    ]
  }
}
