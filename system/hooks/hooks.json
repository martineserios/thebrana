{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/pre-tool-use.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/tdd-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/spec-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "continueOnBlock": true,
            "command": "bash \"$HOME/.claude/hooks/feedback-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "continueOnBlock": true,
            "command": "bash \"$HOME/.claude/hooks/memory-write-gate.sh\""
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/plan-mode-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/worktree-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/doc-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/main-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/branch-verify.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/branch-name-warn.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/no-attribution-commit.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/secret-scan.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git *)",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/commit-msg-verify.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/branch-checkout-warn.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 2000,
            "command": "bash \"$HOME/.claude/hooks/bash-risk-classifier.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "\"$HOME/.local/bin/rtk\" hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/post-tool-use.sh\""
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "timeout": 2000,
            "command": "bash \"$HOME/.claude/hooks/skill-sentinel.sh\""
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "continueOnBlock": true,
            "command": "bash \"$HOME/.claude/hooks/post-plan-challenge.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/post-pr-review.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/task-completed.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/hallucination-detect.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/bash-output-compress.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/post-sale.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "continueOnBlock": true,
            "command": "bash \"$HOME/.claude/hooks/post-tasks-validate.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 10000,
            "command": "bash \"$HOME/.claude/hooks/post-hooks-json.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "async": true,
            "command": "bash \"$HOME/.claude/hooks/memory-index-sync.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "async": true,
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hooks-auto-deploy.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/post-tool-use-failure.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/preflight-model.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/context-inject.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/signal-capture.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 10000,
            "command": "bash \"$HOME/.claude/hooks/session-start.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "bash $HOME/.claude/scripts/cc-changelog-check.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/subagent-context.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/subagent-tracker.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/subagent-tracker.sh\""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/step-completed.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 10000,
            "command": "bash \"$HOME/.claude/hooks/session-end.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 8000,
            "command": "bash -c 'f=\"$HOME/.claude/hooks/goal-completion.sh\"; [ -f \"$f\" ] && bash \"$f\" || echo \"{\\\"continue\\\": true}\"'"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5000,
            "command": "bash \"$HOME/.claude/hooks/stopfailure-logger.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 8000,
            "command": "bash \"$HOME/.claude/hooks/pre-compact.sh\""
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 3000,
            "command": "bash \"$HOME/.claude/hooks/config-change-guard.sh\""
          }
        ]
      }
    ]
  }
}
