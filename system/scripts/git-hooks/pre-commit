#!/usr/bin/env bash
#
# pre-commit — block commits with forbidden attribution trailers
#
# This is the git-side enforcement layer for the no-attribution rule
# (see system/rules/git-discipline.md "Commit attribution — HARD RULE").
#
# It runs at git commit time, before the commit is actually created. If the
# staged commit message contains any forbidden trailer, the commit is rejected.
#
# Deployed by bootstrap.sh to ~/.config/git/hooks/pre-commit. To activate
# globally, run:
#   git config --global core.hooksPath ~/.config/git/hooks
#
# Past sessions have repeatedly violated the soft rule despite explicit user
# instruction. This hook is the final backstop.

set -uo pipefail

# Git pre-commit hooks are passed the commit message file as $1 when invoked
# via commit-msg, but a real pre-commit hook needs to read the staged message
# from .git/COMMIT_EDITMSG (which git writes before pre-commit runs).
#
# Note: technically the right hook for message inspection is `commit-msg`, not
# `pre-commit`. We deploy to BOTH for belt-and-suspenders.

# Resolve the commit message source
if [ -n "${1:-}" ] && [ -f "$1" ]; then
    msg_file="$1"
elif [ -f ".git/COMMIT_EDITMSG" ]; then
    msg_file=".git/COMMIT_EDITMSG"
else
    # No message file available — allow (we can't check)
    exit 0
fi

# Forbidden patterns — case-insensitive substring matches
forbidden_patterns=(
    "Co-Authored-By"
    "co-authored-by"
    "Signed-off-by"
    "🤖 Generated with"
    "Generated with .Claude Code."
    "Claude Code"
    "Claude AI"
    "claude.ai/code"
    "anthropic.com"
)

violations=()
for pattern in "${forbidden_patterns[@]}"; do
    if grep -qiF "$pattern" "$msg_file" 2>/dev/null; then
        violations+=("$pattern")
    fi
done

if [ ${#violations[@]} -gt 0 ]; then
    echo ""
    echo "❌ COMMIT BLOCKED: forbidden attribution trailer(s) detected."
    echo ""
    echo "Found:"
    for v in "${violations[@]}"; do
        echo "  - $v"
    done
    echo ""
    echo "Per ~/.claude/rules/git-discipline.md (Commit attribution — HARD RULE):"
    echo "  No Co-Authored-By, Signed-off-by, AI attribution, or 'Generated with'"
    echo "  trailers in commit messages or PR descriptions. No exceptions."
    echo ""
    echo "Edit the commit message and try again."
    echo ""
    exit 1
fi

# --- Secret scan (t-2138) ---
# Local equivalent of GitHub push protection: block staged credentials at
# commit time. Prefers the deployed hook, falls back to the in-repo source.
SECRET_SCAN="$HOME/.claude/hooks/secret-scan.sh"
if [ ! -x "$SECRET_SCAN" ]; then
    SECRET_SCAN="$(git rev-parse --show-toplevel 2>/dev/null)/system/hooks/secret-scan.sh"
fi
if [ -x "$SECRET_SCAN" ]; then
    bash "$SECRET_SCAN" --staged || exit 1
fi

# --- Context budget check (brana repos only) ---
# Only runs when the current repo has a system/ directory with brana artifacts.
# Threshold mirrors validate.sh Check 5: 28672 bytes.
# Source of truth for this value: validate.sh line 168.

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
SYSTEM_DIR="${REPO_ROOT}/system"

if [ -d "${SYSTEM_DIR}/skills" ] && [ -d "${SYSTEM_DIR}/hooks" ]; then
    # Delegated to the single-source script (t-2177) so this hook and
    # validate.sh Check 5 compute the identical budget and can never drift
    # (that duplication was the root cause of the t-2174 miscount).
    BUDGET_SCRIPT="${SYSTEM_DIR}/scripts/context-budget.sh"
    if [ -f "$BUDGET_SCRIPT" ]; then
        if ! SYSTEM_DIR="$SYSTEM_DIR" bash "$BUDGET_SCRIPT" --check; then
            echo ""
            echo "❌ COMMIT BLOCKED: context budget exceeded (breakdown above)."
            echo "  Reclaim per system/rules/README.md; governance epic: t-2176."
            echo ""
            exit 1
        fi
    fi
fi

# --- Red-verification: register red TDD tests into active-goal.json (t-2216) ---
# Best-effort, NEVER blocks the commit. Registers a newly-added staged test into
# active-goal.json.tests_required[] only when it runs RED, so goal-completion.sh's
# grader-immutability gate cannot be gamed by a green stub or injected fixture
# (ADR-061 §4 invariant 2). Prefers the deployed hook, falls back to in-repo source.
RED_VERIFY="$HOME/.claude/hooks/red-verification.sh"
if [ ! -f "$RED_VERIFY" ]; then
    RED_VERIFY="$(git rev-parse --show-toplevel 2>/dev/null)/system/hooks/red-verification.sh"
fi
[ -f "$RED_VERIFY" ] && bash "$RED_VERIFY" || true

exit 0
