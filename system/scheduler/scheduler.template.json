{
  "version": 1,
  "defaults": {
    "model": "haiku",
    "allowedTools": "Read,Glob,Grep,WebSearch",
    "logRetention": 30,
    "timeoutSeconds": 300
  },
  "jobs": {
    "sync-state": {
      "type": "command",
      "command": "./system/cli/rust/target/release/brana ops sync --auto-commit",
      "command_fallback": "./system/scripts/sync-state.sh push --auto-commit",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08:00:00",
      "enabled": true,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "ADR-015: daily safety net — sync operational state from cache to repos."
    },
    "agentdb-watch": {
      "type": "command",
      "command": "./system/scheduler/check-agentdb-integration.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08:06:00",
      "enabled": true,
      "maxRetries": 1,
      "retryBackoffSec": 60,
      "captureOutput": true,
      "_comment": "Daily check: has AgentDB integration shipped?"
    },
    "staleness-report": {
      "type": "command",
      "command": "./scripts/staleness-report.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:12:00",
      "enabled": true,
      "_comment": "Weekly staleness check on spec docs"
    },
    "cc-changelog-review": {
      "type": "command",
      "command": "./system/scripts/cc-changelog-check.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:18:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "Weekly CC changelog diff — writes ~/.claude/cc-changelog-report.md if changes found (t-512)"
    },
    "reindex-knowledge": {
      "type": "command",
      "command": "./system/cli/rust/target/release/brana ops reindex",
      "command_fallback": "./system/scripts/index-knowledge.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 08:24:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 600,
      "captureOutput": true,
      "_comment": "Weekly full reindex of brana-knowledge dimension docs into ruflo memory."
    },
    "knowledge-decay": {
      "type": "skill",
      "skill": "/brana:reconcile --scope knowledge",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 09:00:00",
      "model": "sonnet",
      "allowedTools": "Read,Glob,Grep,Bash",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 600,
      "captureOutput": true,
      "_comment": "t-936: weekly DECAY — stale dimensions, event log bloat, ruflo noise. Runs after reindex-knowledge."
    },
    "export-patterns": {
      "type": "command",
      "command": "./system/scripts/sync-state.sh export --auto-commit",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 08:30:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 120,
      "captureOutput": true,
      "_comment": "ADR-015: weekly backup of ruflo patterns and decisions to git"
    },
    "index-assumptions": {
      "type": "command",
      "command": "./system/scripts/index-assumptions.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 08:36:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 300,
      "captureOutput": true,
      "_comment": "ADR-021: weekly index of assumptions, field notes, and ADR decisions into ruflo"
    },
    "second-phase-review": {
      "type": "command",
      "command": "./system/scripts/second-phase-check.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 08:42:00",
      "enabled": true,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "ADR-021: weekly check for time-gated second-phase tasks"
    },
    "knowledge-review": {
      "type": "skill",
      "skill": "/brana:memory review",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-01 10:00:00",
      "model": "sonnet",
      "allowedTools": "Read,Glob,Grep,WebSearch,WebFetch",
      "enabled": true,
      "_comment": "Monthly knowledge health check"
    },
    "weekly-review": {
      "type": "skill",
      "skill": "/brana:review",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Fri *-*-* 17:00:00",
      "model": "sonnet",
      "enabled": true,
      "_comment": "Friday weekly portfolio review"
    },
    "morning-check": {
      "type": "skill",
      "skill": "/brana:daily-ops",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon..Fri *-*-* 08:48:00",
      "model": "haiku",
      "enabled": false,
      "_comment": "Daily morning focus card — disabled locally (runs on Oracle for Telegram). Enable only on venture projects."
    },
    "link-check": {
      "type": "command",
      "command": "lychee --config .lychee.toml *.md",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 09:00:00",
      "enabled": false,
      "_comment": "Weekly dead link check (enable after lychee is installed)"
    },
    "content-harvest": {
      "type": "skill",
      "skill": "/brana:harvest 7d --auto",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 22:00:00",
      "model": "sonnet",
      "allowedTools": "Read,Glob,Grep,Bash",
      "enabled": true,
      "timeoutSeconds": 600,
      "captureOutput": true,
      "_comment": "t-680: weekly content harvest — scans all project handoffs, git logs, ADRs, tasks."
    },
    "daily-digest": {
      "type": "command",
      "command": "./system/scheduler/brana-scheduler-digest.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 09:30:00",
      "enabled": false,
      "timeoutSeconds": 30,
      "captureOutput": false,
      "_comment": "t-688: daily Telegram digest summarizing all scheduler runs. Enable on Oracle only (requires ~/.hub-secrets)."
    },
    "feed-poll": {
      "type": "command",
      "command": "brana feed poll --all",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 08:00,12:00,18:00:00",
      "enabled": false,
      "timeoutSeconds": 120,
      "captureOutput": true,
      "_comment": "t-585: poll all registered RSS/Atom feeds 3x daily."
    },
    "statusline-slow-cache": {
      "type": "command",
      "command": "./system/scripts/statusline-slow-cache.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* *:00/5:00",
      "enabled": true,
      "timeoutSeconds": 30,
      "captureOutput": true,
      "_comment": "t-1023: write ruflo health, portfolio pulse, knowledge freshness to statusline slow-cache every 5min"
    },
    "inbox-poll": {
      "type": "command",
      "command": "brana inbox poll",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 09:00:00",
      "enabled": false,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "t-585: poll Gmail for new newsletter emails."
    }
  }
}
