{
  "version": 1,
  "defaults": {
    "model": "haiku",
    "allowedTools": "Read,Glob,Grep,WebSearch",
    "logRetention": 30,
    "timeoutSeconds": 300
  },
  "jobs": {
    "staleness-report": {
      "type": "command",
      "command": "./scripts/staleness-report.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 09:00:00",
      "enabled": false,
      "_comment": "Weekly staleness check on spec docs (enable after scripts/ exist)"
    },
    "link-check": {
      "type": "command",
      "command": "lychee --config .lychee.toml *.md",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon *-*-* 09:00:00",
      "enabled": false,
      "_comment": "Weekly dead link check (enable after lychee is installed)"
    },
    "knowledge-review": {
      "type": "skill",
      "skill": "/knowledge-review",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-01 10:00:00",
      "model": "sonnet",
      "allowedTools": "Read,Glob,Grep,WebSearch,WebFetch",
      "enabled": false,
      "_comment": "Monthly knowledge health check"
    },
    "morning-check": {
      "type": "skill",
      "skill": "/morning",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Mon..Fri *-*-* 08:00:00",
      "model": "haiku",
      "enabled": false,
      "_comment": "Daily morning focus card (set project to your active venture)"
    },
    "weekly-review": {
      "type": "skill",
      "skill": "/weekly-review",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Fri *-*-* 17:00:00",
      "model": "sonnet",
      "enabled": false,
      "_comment": "Friday weekly portfolio review"
    },
    "agentdb-watch": {
      "type": "command",
      "command": "./system/scheduler/check-agentdb-integration.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 09:02:00",
      "enabled": true,
      "maxRetries": 1,
      "retryBackoffSec": 60,
      "captureOutput": true,
      "_comment": "Daily check: has claude-flow + AgentDB integration shipped? (parked ms-007)"
    },
    "reindex-knowledge": {
      "type": "command",
      "command": "./system/scripts/index-knowledge.sh",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 03:00:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 600,
      "captureOutput": true,
      "_comment": "Weekly full reindex of brana-knowledge dimension docs into ruflo memory"
    },
    "sync-state": {
      "type": "command",
      "command": "./system/scripts/sync-state.sh push --auto-commit",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "*-*-* 09:00:00",
      "enabled": true,
      "timeoutSeconds": 60,
      "captureOutput": true,
      "_comment": "ADR-015: daily safety net — sync operational state from cache to repos"
    },
    "export-patterns": {
      "type": "command",
      "command": "./system/scripts/sync-state.sh export --auto-commit",
      "project": "~/enter_thebrana/thebrana",
      "schedule": "Sun *-*-* 03:05:00",
      "enabled": true,
      "maxRetries": 1,
      "timeoutSeconds": 120,
      "captureOutput": true,
      "_comment": "ADR-015: weekly backup of claude-flow patterns and decisions to git"
    }
  }
}
