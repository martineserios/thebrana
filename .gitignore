# Runtime state (ruflo / agentdb)
.swarm/
.claude/memory.db
agentdb.rvf*
.claude-flow/
system/state/decisions/

# Local Claude Code config
.claude/settings.json

# Obsidian local config (created on vault open)
.obsidian/

# MCP config (local dev)
.mcp.json
ruvector.db

# Processing inbox — drop files here for Claude to process (transcriptions, docs, etc.)
inbox/

# Statusline cache (derived from tasks.json by post-tasks-validate hook)
*.statusline.tsv

# Python virtual environment
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Rust build artifacts
target/

# Node.js
node_modules/
.claude/CLAUDE.local.md
.claude/sessions/

# Auto-generated ruflo memory export — may capture secrets, never track (secret-leak incident 2026-06-20)
system/state/patterns-export.json

# Per-repo backlog config (active_epic, theme) — personal, volatile, per-machine
# working state. Tracking it causes cross-machine clobber + merge conflicts (t-2158/t-2155).
.claude/tasks-config.json

# Lock sidecars from util::lock_sidecar (<store>.json.lock) — created on every
# locked write to tasks.json / queue / remind stores. Transient, never tracked (t-2166).
*.json.lock

# graphify graph artifacts — build output, rebuilt locally (ADR-064, t-2275)
graphify-out/
