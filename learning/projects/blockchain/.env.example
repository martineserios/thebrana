# SenseLedger contracts — environment variables for Sepolia deploys.
# Copy this to .env (which is .gitignored) and fill it in.
# Never reuse a key across projects. Fund it only with testnet ETH.

SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=

# Optional: address that should receive REGISTRAR_ROLE on StationNFT
# (i.e. your backend wallet-bridge service). Leave blank to use the deployer.
REGISTRAR_ADDRESS=
