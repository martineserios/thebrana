# SenseLedger data-eng scaffold — local, non-secret defaults.
# Copy to `.env` and adjust if you want.

POSTGRES_USER=senseledger
POSTGRES_PASSWORD=senseledger
POSTGRES_DB=senseledger

TIMESCALE_USER=senseledger
TIMESCALE_PASSWORD=senseledger
TIMESCALE_DB=senseledger

# MinIO (scripted usage)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RAW=senseledger-raw
S3_BUCKET_LAKE=senseledger-lake

# Redpanda / Kafka
KAFKA_BOOTSTRAP=localhost:19092
KAFKA_TOPIC_READINGS=senseledger.readings.v1

# OTel
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=senseledger-learning
