# Oracle Cloud credentials
# Find compartment OCID: OCI Console → Identity → Compartments
COMPARTMENT_OCID=ocid1.compartment.oc1..xxxxxxxxxxxx
OCI_REGION=sa-saopaulo-1

# SSH key for VM access
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TOKEN_HERE  # placeholder

# Git repo for journal sync (SSH URL)
GIT_REPO_URL=git@github.com:martineserios/personal.git

# Instance sizing (defaults: 1 OCPU, 6 GB — within Free Tier)
# OCPUS=1
# MEMORY_GB=6
# DISPLAY_NAME=personal-bot
